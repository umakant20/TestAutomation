{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ════════════════════════════════════════════════════════════════════════════
  // PLACEHOLDERS — fill these in before running.
  // These values are loaded as defaults in the UI but can be overridden there.
  //
  // For local dev it is safer to use dotnet user-secrets instead:
  //   cd PRImpactAnalyzer.Web
  //   dotnet user-secrets set "PrImpactAnalyzer:AzureDevOpsPat" "your-pat-here"
  //   dotnet user-secrets set "PrImpactAnalyzer:CopilotApiKey"  "your-key-here"
  // ════════════════════════════════════════════════════════════════════════════
  "PrImpactAnalyzer": {
    // Azure DevOps PAT — needs scope: Code (Read), Pull Request Threads (Read)
    // Generate at: https://dev.azure.com/{yourorg}/_usersSettings/tokens
    "AzureDevOpsPat": "*** PASTE YOUR AZURE DEVOPS PAT HERE ***",

    // GitHub Copilot API key
    // Generate at: https://github.com/settings/tokens  (scope: copilot)
    "CopilotApiKey": "*** PASTE YOUR GITHUB COPILOT API KEY HERE ***",

    // Copilot endpoint — use default unless your org routes via a proxy
    "CopilotApiEndpoint": "https://api.githubcopilot.com/chat/completions",
    "CopilotModel": "gpt-4o",

    // Default local paths — override in the UI per-run
    "DefaultDevRepoPath": "",
    "DefaultTestRepoPath": ""
  }
}
