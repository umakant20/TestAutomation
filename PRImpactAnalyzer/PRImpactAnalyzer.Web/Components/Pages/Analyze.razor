@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using PRImpactAnalyzer.Core.Models
@using PRImpactAnalyzer.Core.Pipeline
@using PRImpactAnalyzer.Infrastructure.Http

@inject AnalysisPipeline Pipeline
@inject ManualCopilotBridgeOrchestrator CopilotBridge
@inject IConfiguration Config
@inject ILogger<Analyze> Logger

<PageTitle>PR Test Impact Analyzer</PageTitle>

<div class="analyzer-page">

    <!-- ── Step 1: Input form ──────────────────────────────────────────────── -->
    <section class="card form-card">
        <h2 class="card-title">🔧 Step 1 — Analysis Settings</h2>

        <div class="form-grid">
            <div class="form-group span-2">
                <label>Azure DevOps PR URL</label>
                <input @bind="Request.DevRepoPrUrl" placeholder="https://dev.azure.com/org/project/_git/repo/pullrequest/123" class="input-full" disabled="@(Prepared != null)" />
            </div>

            <div class="form-group">
                <label>Dev Repo Local Path</label>
                <input @bind="Request.DevRepoLocalPath" placeholder="C:\source\MyApp.Dev" class="input-full" disabled="@(Prepared != null)" />
                <span class="hint">Local clone of the .NET / ColdFusion repo</span>
            </div>

            <div class="form-group">
                <label>Test Repo Local Path</label>
                <input @bind="Request.TestRepoLocalPath" placeholder="C:\source\MyApp.Tests" class="input-full" disabled="@(Prepared != null)" />
                <span class="hint">Local clone of the C# SpecFlow / Reqnroll repo</span>
            </div>

            <div class="form-group cred-group span-2">
                <div class="cred-header">🔑 Azure DevOps PAT <span class="cred-note">(stored in memory only — used solely to call your own ADO organisation)</span></div>
                <input @bind="Request.AzureDevOpsPat" type="password" placeholder="Paste your ADO Personal Access Token" class="input-full" disabled="@(Prepared != null)" />
                <span class="hint">
                    Generate at: <code>dev.azure.com/{org} → User Settings → Personal Access Tokens</code> — scope: <strong>Code (Read)</strong>
                </span>
            </div>
        </div>

        <div class="form-actions">
            @if (Prepared == null)
            {
                <button @onclick="RunPrepare" disabled="@IsRunning" class="btn btn-primary">
                    @if (IsRunning) { <span class="spinner"></span><span>Fetching diff &amp; scanning tests…</span> }
                    else { <span>🔍 Fetch Diff &amp; Build Prompt</span> }
                </button>
            }
            else
            {
                <button @onclick="ResetAll" class="btn btn-secondary">↺ Start New Analysis</button>
            }
        </div>

        @if (!string.IsNullOrEmpty(StatusMessage))
        {
            <div class="status-bar @(IsError ? "status-error" : "status-info")">@StatusMessage</div>
        }
    </section>

    <!-- ── Progress log ─────────────────────────────────────────────────────── -->
    @if (ProgressLog.Any())
    {
        <section class="card progress-card">
            <h3 class="card-title">📋 Progress</h3>
            <div class="progress-log">
                @foreach (var entry in ProgressLog)
                {
                    <div class="log-line @entry.Level.ToLower()">
                        <span class="log-time">@entry.Time.ToString("HH:mm:ss")</span>
                        <span class="log-msg">@entry.Message</span>
                    </div>
                }
            </div>
        </section>
    }

    <!-- ── Step 2: Manual Copilot Chat bridge — one block per prompt chunk ──── -->
    @if (Prepared != null && Prepared.PromptChunks.Any())
    {
        @for (int i = 0; i < Prepared.PromptChunks.Count; i++)
        {
            var chunk = Prepared.PromptChunks[i];
            var idx = i; // capture for closures below

            <section class="card chunk-card">
                <h2 class="card-title">
                    🤖 Step 2 — Paste into Copilot Chat
                    @if (chunk.TotalChunks > 1)
                    {
                        <span class="chunk-badge">Chunk @(idx + 1) of @chunk.TotalChunks</span>
                    }
                    @if (ChunkResponses.ContainsKey(idx))
                    {
                        <span class="badge badge-added">✓ Parsed</span>
                    }
                </h2>

                <p class="hint">
                    @chunk.ScenarioCount scenario(s) in this chunk.
                    In Visual Studio: <strong>View → GitHub Copilot Chat</strong>, paste the prompt below, send it, then paste the JSON reply into the box underneath.
                </p>

                <div class="prompt-actions">
                    <button @onclick="() => CopyPromptToClipboard(idx)" class="btn btn-secondary">📋 Copy Prompt</button>
                    <button @onclick="() => SavePromptToFile(idx)" class="btn btn-secondary">💾 Save to File</button>
                    @if (SavedFilePaths.TryGetValue(idx, out var savedPath))
                    {
                        <span class="hint">Saved: <code>@savedPath</code></span>
                    }
                </div>

                <textarea readonly class="prompt-textarea" id="prompt-@idx">@chunk.PromptText</textarea>
                <div class="hint token-estimate">~@EstimateTokens(chunk.PromptText) tokens (rough estimate)</div>

                <h4 style="margin-top:18px;">Paste Copilot's response here:</h4>
                <textarea value="@GetPastedResponse(idx)" @oninput="@(e => SetPastedResponse(idx, e.Value?.ToString() ?? string.Empty))" @onchange="@(e => SetPastedResponse(idx, e.Value?.ToString() ?? string.Empty))" rows="8" class="input-full" placeholder='{"impacted":[{"s":"...","f":"...","m":"...","c":"H","r":"..."}]}'></textarea>

                <div class="form-actions">
                    <button @onclick="() => ParseChunk(idx)" disabled="@(string.IsNullOrWhiteSpace(GetPastedResponse(idx)))" class="btn btn-primary">
                        ✅ Parse Response
                    </button>
                </div>

                @if (ChunkResponses.TryGetValue(idx, out var chunkResult))
                {
                    @if (chunkResult.Count == 0)
                    {
                        <div class="status-bar status-info">Parsed OK — 0 impacted scenarios in this chunk.</div>
                    }
                    else if (chunkResult.Any(r => r.ScenarioName.StartsWith("[")))
                    {
                        <div class="status-bar status-error">
                            ⚠️ Could not parse this response as valid JSON: @chunkResult[0].Reason
                        </div>
                    }
                    else
                    {
                        <div class="status-bar status-info">✅ @chunkResult.Count impacted scenario(s) found in this chunk:</div>
                        <ul class="chunk-preview-list">
                            @foreach (var r in chunkResult)
                            {
                                <li><strong>@r.ScenarioName</strong> — <span class="badge badge-@r.Confidence.ToString().ToLower()">@r.Confidence</span></li>
                            }
                        </ul>
                    }
                }
            </section>
        }

        @if (AllChunksParsed && Result == null)
        {
            <section class="card">
                <button @onclick="FinalizeResults" class="btn btn-primary">🎯 Show Final Impact Report</button>
            </section>
        }
    }

    <!-- ── Step 3: Results ──────────────────────────────────────────────────── -->
    @if (Result != null)
    {
        <section class="card summary-card">
            <div class="summary-grid">
                <div class="summary-stat"><span class="stat-value">@Result.ImpactedScenarios.Count</span><span class="stat-label">Impacted Scenarios</span></div>
                <div class="summary-stat"><span class="stat-value text-high">@Result.ImpactedScenarios.Count(s => s.Confidence == ConfidenceLevel.High)</span><span class="stat-label">HIGH confidence</span></div>
                <div class="summary-stat"><span class="stat-value text-medium">@Result.ImpactedScenarios.Count(s => s.Confidence == ConfidenceLevel.Medium)</span><span class="stat-label">MEDIUM confidence</span></div>
                <div class="summary-stat"><span class="stat-value text-verify">@Result.ImpactedScenarios.Count(s => s.Confidence == ConfidenceLevel.Verify)</span><span class="stat-label">Needs VERIFY</span></div>
                <div class="summary-stat"><span class="stat-value">@Result.AllScenarios.Count</span><span class="stat-label">Total Scenarios Scanned</span></div>
                <div class="summary-stat"><span class="stat-value">@Result.ChangedSymbols.Count</span><span class="stat-label">Changed Symbols</span></div>
            </div>
        </section>

        @if (Result.ImpactedScenarios.Any())
        {
            <section class="card results-card">
                <div class="results-header">
                    <h2 class="card-title">🎯 Impacted Test Scenarios</h2>
                    <div class="filter-bar">
                        <label>Filter:</label>
                        <button @onclick='() => SetFilter("ALL")' class="@FilterClass("ALL")">All</button>
                        <button @onclick='() => SetFilter("HIGH")' class="@FilterClass("HIGH")">HIGH</button>
                        <button @onclick='() => SetFilter("MEDIUM")' class="@FilterClass("MEDIUM")">MEDIUM</button>
                        <button @onclick='() => SetFilter("VERIFY")' class="@FilterClass("VERIFY")">VERIFY</button>
                    </div>
                </div>

                <div class="table-wrap">
                    <table class="results-table">
                        <thead>
                            <tr><th>#</th><th>Scenario Name</th><th>Feature File</th><th>Matched Change</th><th>Confidence</th><th>Reason</th></tr>
                        </thead>
                        <tbody>
                            @{ var filtered = FilteredScenarios(); int idx2 = 1; }
                            @foreach (var scenario in filtered)
                            {
                                <tr class="@RowClass(scenario.Confidence)">
                                    <td class="col-idx">@(idx2++)</td>
                                    <td class="col-name"><strong>@scenario.ScenarioName</strong></td>
                                    <td class="col-file"><code>@scenario.FeatureFile</code></td>
                                    <td class="col-change">@scenario.MatchedChange</td>
                                    <td class="col-conf"><span class="badge badge-@scenario.Confidence.ToString().ToLower()">@scenario.Confidence.ToString().ToUpper()</span></td>
                                    <td class="col-reason">@scenario.Reason</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
        else
        {
            <section class="card">
                <div class="empty-state">
                    <span class="empty-icon">✅</span>
                    <strong>No impacted scenarios found</strong>
                    <span>Copilot found no test scenarios connected to the changed symbols in this PR.</span>
                </div>
            </section>
        }

        <section class="card">
            <details>
                <summary class="card-title">🧩 Changed Symbols Extracted (@Result.ChangedSymbols.Count)</summary>
                <div class="table-wrap" style="margin-top:12px;">
                    <table class="results-table">
                        <thead><tr><th>File</th><th>Symbol</th><th>Kind</th><th>Change</th></tr></thead>
                        <tbody>
                            @foreach (var sym in Result.ChangedSymbols)
                            {
                                <tr>
                                    <td><code>@sym.File</code></td>
                                    <td><strong>@sym.Symbol</strong>@(sym.OldSymbol != null ? $" (was: {sym.OldSymbol})" : "")</td>
                                    <td>@sym.Kind</td>
                                    <td><span class="badge badge-@sym.Change.ToString().ToLower()">@sym.Change</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </details>
        </section>
    }
    else if (PrepareError != null)
    {
        <section class="card error-card">
            <h3>❌ Could not prepare analysis</h3>
            <p>@PrepareError</p>
        </section>
    }
</div>

<script>
    window.copyToClipboard = (elementId) => {
        const el = document.getElementById(elementId);
        if (el) { el.select(); document.execCommand('copy'); }
    };
</script>

@code {
    private AnalysisRequest Request { get; set; } = new();
    private PreparedAnalysis? Prepared { get; set; }
    private AnalysisResult? Result { get; set; }
    private bool IsRunning { get; set; }
    private bool IsError { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string? PrepareError { get; set; }
    private string ActiveFilter { get; set; } = "ALL";
    private List<LogEntry> ProgressLog { get; set; } = new();

    private Dictionary<int, string> PastedResponses { get; set; } = new();
    private Dictionary<int, List<ImpactedScenario>> ChunkResponses { get; set; } = new();
    private Dictionary<int, string> SavedFilePaths { get; set; } = new();

    private bool AllChunksParsed =>
        Prepared != null && Prepared.PromptChunks.Count > 0 &&
        Prepared.PromptChunks.Select((_, i) => i).All(i => ChunkResponses.ContainsKey(i));

    protected override void OnInitialized()
    {
        var cfg = Config.GetSection("PrImpactAnalyzer");
        Request.AzureDevOpsPat    = cfg["AzureDevOpsPat"] ?? string.Empty;
        Request.DevRepoLocalPath  = cfg["DefaultDevRepoPath"] ?? string.Empty;
        Request.TestRepoLocalPath = cfg["DefaultTestRepoPath"] ?? string.Empty;
    }

    // ── Step 1 → builds prompt chunks, no LLM call ──────────────────────────────
    private async Task RunPrepare()
    {
        if (string.IsNullOrWhiteSpace(Request.DevRepoPrUrl)) { SetStatus("Please enter an Azure DevOps PR URL.", true); return; }
        if (string.IsNullOrWhiteSpace(Request.TestRepoLocalPath)) { SetStatus("Please enter the local path to the test repo.", true); return; }

        IsRunning = true; IsError = false; StatusMessage = string.Empty; PrepareError = null;
        ProgressLog.Clear(); Prepared = null; Result = null;
        PastedResponses.Clear(); ChunkResponses.Clear(); SavedFilePaths.Clear();
        StateHasChanged();

        Log("INFO", $"Fetching PR diff: {Request.DevRepoPrUrl}");

        try
        {
            Prepared = await Pipeline.PrepareAsync(Request);

            if (!string.IsNullOrEmpty(Prepared.Warning))
            {
                Log("ERROR", Prepared.Warning);
                SetStatus(Prepared.Warning, true);
            }
            else
            {
                Log("INFO", $"{Prepared.ChangedSymbols.Count} changed symbols extracted.");
                Log("INFO", $"{Prepared.AllScenarios.Count} scenarios scanned in test repo.");
                Log("INFO", $"{Prepared.PromptChunks.Count} prompt chunk(s) ready to paste into Copilot Chat.");
                SetStatus($"✅ Ready. Paste {(Prepared.PromptChunks.Count == 1 ? "the prompt" : $"each of the {Prepared.PromptChunks.Count} prompts")} below into Copilot Chat.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Prepare step failed");
            Log("ERROR", ex.Message);
            PrepareError = ex.Message;
            SetStatus($"Error: {ex.Message}", true);
        }
        finally
        {
            IsRunning = false;
            StateHasChanged();
        }
    }

    // ── Step 2 actions ───────────────────────────────────────────────────────────
    private async Task CopyPromptToClipboard(int idx)
    {
        await JsInvokeCopy(idx);
    }

    private async Task JsInvokeCopy(int idx)
    {
        // JS interop is wired via IJSRuntime in a full build; for now this calls the
        // inline script's copyToClipboard helper through the injected IJSRuntime.
        await JsRuntime.InvokeVoidAsync("copyToClipboard", $"prompt-{idx}");
    }

    private async Task SavePromptToFile(int idx)
    {
        var chunk = Prepared!.PromptChunks[idx];
        var path = await CopilotBridge.SavePromptToFileAsync(chunk.PromptText, idx);
        SavedFilePaths[idx] = path;
    }

    private string GetPastedResponse(int idx) => PastedResponses.TryGetValue(idx, out var v) ? v : string.Empty;

    private void SetPastedResponse(int idx, string value) => PastedResponses[idx] = value;

    private string? LastParseFeedback { get; set; }

    private void ParseChunk(int idx)
    {
        var response = GetPastedResponse(idx);
        if (string.IsNullOrWhiteSpace(response))
        {
            LastParseFeedback = "Paste a response before parsing — the textbox is empty.";
            return;
        }

        var parsed = Pipeline.ParseChunkResponse(response);
        ChunkResponses[idx] = parsed;

        if (parsed.Count == 0)
        {
            LastParseFeedback = $"Chunk {idx + 1}: parsed successfully — 0 impacted scenarios in this chunk. " +
                "(This is expected if none of this chunk's scenarios matched a changed symbol.)";
            Log("INFO", $"Chunk {idx + 1} parsed — 0 impacted scenarios (empty array, not an error).");
        }
        else if (parsed.Any(p => p.ScenarioName.StartsWith("[")))
        {
            LastParseFeedback = $"Chunk {idx + 1}: could not parse the pasted text as valid JSON. " +
                "Check that you copied Copilot's full reply, including the opening { and closing }.";
            Log("ERROR", $"Chunk {idx + 1} parse failed: {parsed[0].Reason}");
        }
        else
        {
            LastParseFeedback = $"Chunk {idx + 1}: parsed successfully — {parsed.Count} impacted scenario(s) found.";
            Log("INFO", $"Chunk {idx + 1} parsed — {parsed.Count} impacted scenario(s) found in this chunk.");
        }
    }

    private void FinalizeResults()
    {
        if (Prepared == null) return;
        var orderedChunkResults = Prepared.PromptChunks
            .Select((_, i) => ChunkResponses.TryGetValue(i, out var r) ? r : new List<ImpactedScenario>())
            .ToList();

        Result = Pipeline.FinalizeResult(Prepared, orderedChunkResults);
        Log("INFO", $"Finalized — {Result.ImpactedScenarios.Count} total impacted scenarios after dedupe.");
        SetStatus($"✅ Analysis complete. {Result.ImpactedScenarios.Count} impacted scenarios found.");
    }

    private void ResetAll()
    {
        Prepared = null; Result = null; PrepareError = null;
        PastedResponses.Clear(); ChunkResponses.Clear(); SavedFilePaths.Clear();
        ProgressLog.Clear(); StatusMessage = string.Empty; ActiveFilter = "ALL";
    }

    private void SetStatus(string message, bool error = false) { StatusMessage = message; IsError = error; }
    private void Log(string level, string message) => ProgressLog.Add(new LogEntry(DateTime.Now, level, message));
    private void SetFilter(string f) => ActiveFilter = f;
    private string FilterClass(string f) => "btn btn-filter" + (ActiveFilter == f ? " active" : "");

    private IEnumerable<ImpactedScenario> FilteredScenarios()
    {
        if (Result is null) return Enumerable.Empty<ImpactedScenario>();
        return ActiveFilter == "ALL"
            ? Result.ImpactedScenarios
            : Result.ImpactedScenarios.Where(s => s.Confidence.ToString().Equals(ActiveFilter, StringComparison.OrdinalIgnoreCase));
    }

    private static string RowClass(ConfidenceLevel c) => c switch
    {
        ConfidenceLevel.High   => "row-high",
        ConfidenceLevel.Medium => "row-medium",
        _                      => "row-verify"
    };

    /// <summary>Rough token estimate for display only — ~4 chars per token is a standard approximation.</summary>
    private static int EstimateTokens(string text) => text.Length / 4;

    private record LogEntry(DateTime Time, string Level, string Message);

    [Inject] private IJSRuntime JsRuntime { get; set; } = default!;
}
